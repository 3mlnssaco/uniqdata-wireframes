// UniQdata v7 Complete ERD — 51 Tables (2-Server Architecture)
// health_db (Core, 4 schemas, 33 tables) + uniqdata_db (Business, 18 tables)
// 2026-03-01 Core v2.6.0 기준 전면 리뉴얼

// ═══════════════════════════════════════
// TableGroup 선언 (레이아웃 그룹핑)
// ═══════════════════════════════════════

// --- health_db: Core Server ---

TableGroup core_member [headercolor: #7c3aed] {
  user_email
  user_passkey
}

TableGroup core_auth [headercolor: #8b5cf6] {
  user_wallet
  wallet_secret
  wallet_credential_binding
  wallet_recovery_request
  escrow_secret
}

TableGroup uq_cdm_person [headercolor: #6366f1] {
  cdm_person
  observation_period
  device_registry
}

TableGroup uq_cdm_clinical [headercolor: #6366f1] {
  cdm_measurement
  cdm_measurement_highfreq
  cdm_observation
  cdm_condition_occurrence
  cdm_drug_exposure
  cdm_device_exposure
  cdm_note
  cdm_episode
  cdm_episode_event
}

TableGroup uq_cdm_consent [headercolor: #6366f1] {
  consent
  cdm_consent_scope
}

TableGroup uq_cdm_system [headercolor: #6366f1] {
  anchor_log
  audit_log
  data_anchor_batch
  record_revision
  quality_audit
  dataset_registry
  uniqdata_concept
  feature_flag
}

TableGroup uq_mapping [headercolor: #a78bfa] {
  research_participant
  institution_registry
  linking_token
  deletion_audit_log
}

// --- uniqdata_db: Business Server ---

TableGroup biz_enterprise [headercolor: #059669] {
  enterprises
  enterprise_members
}

TableGroup biz_research [headercolor: #059669] {
  projects
  project_design
  project_data_requirement
  project_eligibility
  project_milestones
  participants
  participation_criteria
  data_requests
}

TableGroup biz_irb [headercolor: #059669] {
  irb_submissions
  irb_documents
  irb_review_comments
  irb_workflow_history
}

TableGroup biz_wallet [headercolor: #059669] {
  project_wallets
  project_wallet_transactions
  project_budget
}

TableGroup biz_settlement [headercolor: #059669] {
  settlement_batches
  settlement_items
}

TableGroup biz_phase2 [headercolor: #6b7280] {
  synthetic_datasets
  fl_rounds
}

TableGroup biz_system [headercolor: #059669] {
  webhook_events
}

// ═══════════════════════════════════════════════════════
// ░░░ health_db — Core Server (FastAPI:8000) ░░░
// 33 Tables · 4 Schemas · PostgreSQL 15
// core_member(2) + core_auth(5) + uq_cdm(22) + uq_mapping(4)
// ═══════════════════════════════════════════════════════

// ─── Schema: core_member (인증) ───

Table user_email [headercolor: #7c3aed] {
  id uuid [pk]
  person_id uuid [unique, not null, note: 'FK → cdm_person.person_id']
  email varchar(255) [unique, not null]
  password_hash varchar(255) [not null, note: 'bcrypt direct (passlib 제거)']
  display_name varchar(100)
  is_active boolean [default: true]
  created_at timestamp [default: `NOW()`]
  last_login_at timestamp
}

Table user_passkey [headercolor: #7c3aed] {
  id uuid [pk]
  person_id uuid [not null, note: 'FK → cdm_person.person_id']
  credential_id varchar(512) [unique, not null, note: 'WebAuthn credential ID']
  public_key bytea [not null, note: 'COSE 공개키']
  sign_count bigint [default: 0]
  aaguid varchar(36)
  device_name varchar(100)
  transports varchar(100) [note: 'usb,ble,nfc,internal']
  prf_hash varchar(128) [note: 'PRF 지원 시 해시']
  is_active boolean [default: true]
  created_at timestamp [default: `NOW()`]
  last_used_at timestamp
}

// ─── Schema: core_auth (지갑 격리 — Layer 1) ───

Table user_wallet [headercolor: #8b5cf6] {
  id uuid [pk]
  person_id uuid [unique, not null, note: 'FK → cdm_person.person_id']
  wallet_address varchar(60) [unique, not null, note: 'rXXXXX... XRPL 주소']
  wallet_type varchar(20) [default: 'USER']
  encrypted_seed bytea [not null, note: 'KMS 암호화된 시드']
  created_at timestamp [default: `NOW()`]
  last_used_at timestamp

  Note: 'wallet_address, encrypted_seed는 이 스키마에만 존재. uq_cdm에 절대 노출 안 됨.'
}

Table wallet_secret [headercolor: #8b5cf6] {
  id uuid [pk]
  wallet_id uuid [unique, not null, note: 'FK → user_wallet.id']
  encrypted_seed_prf bytea [note: 'PRF 암호화 시드']
  prf_salt bytea [note: '32바이트 salt']
  encrypted_seed_hsm bytea [note: 'HSM 암호화 시드 (이중 암호화)']
  hsm_key_id varchar(100)
  encryption_version int [default: 1]
  created_at timestamp [default: `NOW()`]
  updated_at timestamp
}

Table wallet_credential_binding [headercolor: #8b5cf6] {
  id uuid [pk]
  wallet_id uuid [not null, note: 'FK → user_wallet.id']
  credential_id varchar(512) [not null, note: 'FK → user_passkey.credential_id']
  encrypted_seed_prf bytea [not null]
  prf_salt bytea [not null]
  binding_signature varchar(256)
  xrpl_tx_hash varchar(64)
  status varchar(20) [default: 'active', note: 'active|revoked']
  revoked_at timestamp
  revoke_reason varchar(200)
  created_at timestamp [default: `NOW()`]

  indexes {
    (wallet_id, credential_id) [unique]
  }
}

Table wallet_recovery_request [headercolor: #8b5cf6] {
  id uuid [pk]
  wallet_id uuid [not null]
  owner_id uuid [not null]
  kyc_verified boolean [default: false]
  kyc_verified_at timestamp
  identity_hash varchar(128)
  sms_verified boolean [default: false]
  email_verified boolean [default: false]
  waiting_period_start timestamp
  waiting_period_end timestamp
  admin_approval_required boolean [default: true]
  admin_approved_by uuid
  status varchar(30) [default: 'pending', note: 'pending|kyc_verified|waiting|admin_review|approved|rejected|completed']
  new_passkey_id uuid
  xrpl_tx_hash varchar(64)
  created_at timestamp [default: `NOW()`]
  completed_at timestamp
}

Table escrow_secret [headercolor: #8b5cf6] {
  id uuid [pk]
  project_id uuid [unique, not null, note: '논리참조 → uniqdata_db.research.project']
  wallet_address varchar(60) [unique, not null]
  encrypted_seed bytea [not null, note: 'KMS 암호화']
  encryption_key_id varchar(100)
  encryption_version int [default: 1]
  created_at timestamp [default: `NOW()`]
  rotated_at timestamp
}

// ─── Schema: uq_cdm (골든 테이블 — OMOP CDM) ───

Table cdm_person [headercolor: #6366f1] {
  person_id uuid [pk]
  gender_concept_id int
  year_of_birth int
  month_of_birth int
  day_of_birth int
  race_concept_id int
  ethnicity_concept_id int
  location_id uuid
  auth_user_id uuid [note: '논리참조 → core_auth.user_wallet (cross-schema)']
  created_at timestamp [default: `NOW()`]
  updated_at timestamp

  Note: 'OMOP CDM person 테이블. wallet_address 미포함.'
}

Table observation_period [headercolor: #6366f1] {
  observation_period_id uuid [pk]
  person_id uuid [ref: > cdm_person.person_id, not null]
  observation_period_start_date date [not null]
  observation_period_end_date date
  period_type_concept_id int
}

Table device_registry [headercolor: #6366f1] {
  device_id uuid [pk]
  person_id uuid [ref: > cdm_person.person_id, not null]
  device_name varchar(100)
  device_type varchar(50) [note: 'wearable|cgm|bp_monitor|scale|oximeter|app']
  manufacturer varchar(100)
  model varchar(100)
  serial_number varchar(100)
  firmware_version varchar(50)
  app_version varchar(50)
  trust_grade varchar(10) [note: 'A|B|C|D']
  is_active boolean [default: true]
  paired_at timestamp
  last_sync_at timestamp
}

// ─── uq_cdm: Clinical Fact Tables (13-metadata mixin) ───
// 공통 메타데이터: source_type, source_device_id, occurred_at, reported_at, ingested_at,
// trust_level, quality_flag, sensitivity_level, encrypted_value, encryption_key_id,
// record_hash, anchor_batch_id, anchor_merkle_position

Table cdm_measurement [headercolor: #6366f1] {
  measurement_id uuid [pk]
  person_id uuid [ref: > cdm_person.person_id, not null]
  measurement_concept_id int [not null]
  measurement_type_concept_id int
  value_as_number decimal(18,6)
  value_as_concept_id int
  unit_concept_id int
  range_low decimal(18,6)
  range_high decimal(18,6)
  source_value varchar(200)
  source_concept_id int
  unit_source_value varchar(50)
  // -- 13 metadata columns --
  source_type varchar(30) [note: 'manual|wearable|cgm|lab|import']
  source_device_id uuid [ref: > device_registry.device_id]
  occurred_at timestamp [not null]
  trust_level varchar(10) [note: 'A|B|C|D']
  quality_flag varchar(20) [note: 'valid|suspect|missing|error']
  sensitivity_level varchar(10) [note: 'normal|sensitive|restricted']
  record_hash varchar(64) [note: 'SHA-256']

  indexes {
    (person_id, measurement_concept_id, occurred_at)
    record_hash
  }
}

Table cdm_measurement_highfreq [headercolor: #6366f1] {
  measurement_id uuid [pk]
  person_id uuid [not null]
  measurement_concept_id int [not null]
  measurement_type_concept_id int
  value_as_number decimal(18,6) [not null]
  unit_concept_id int
  source_value varchar(200)
  // -- 13 metadata columns --
  source_type varchar(30)
  occurred_at timestamp [not null]
  trust_level varchar(10)
  quality_flag varchar(20)
  record_hash varchar(64)

  Note: '고빈도 데이터 (CGM 5분 간격 등). occurred_at 기준 파티셔닝. FK 없음.'

  indexes {
    (person_id, measurement_concept_id, occurred_at)
  }
}

Table cdm_observation [headercolor: #6366f1] {
  observation_id uuid [pk]
  person_id uuid [ref: > cdm_person.person_id, not null]
  observation_concept_id int [not null]
  observation_type_concept_id int
  value_as_number decimal(18,6)
  value_as_string text
  value_as_concept_id int
  unit_concept_id int
  symptom_detail jsonb [note: '증상 상세 (자유텍스트 구조화)']
  source_value varchar(200)
  source_concept_id int
  // -- 13 metadata columns --
  source_type varchar(30)
  source_device_id uuid [ref: > device_registry.device_id]
  occurred_at timestamp [not null]
  trust_level varchar(10)
  quality_flag varchar(20)
  sensitivity_level varchar(10)
  record_hash varchar(64)
}

Table cdm_condition_occurrence [headercolor: #6366f1] {
  condition_occurrence_id uuid [pk]
  person_id uuid [ref: > cdm_person.person_id, not null]
  condition_concept_id int [not null]
  condition_type_concept_id int
  condition_start_date date
  condition_end_date date
  condition_status_concept_id int
  stop_reason varchar(200)
  source_value varchar(200)
  source_concept_id int
  condition_source_value varchar(200)
  // -- 13 metadata columns --
  source_type varchar(30)
  source_device_id uuid [ref: > device_registry.device_id]
  occurred_at timestamp [not null]
  trust_level varchar(10)
  quality_flag varchar(20)
  record_hash varchar(64)
}

Table cdm_drug_exposure [headercolor: #6366f1] {
  drug_exposure_id uuid [pk]
  person_id uuid [ref: > cdm_person.person_id, not null]
  drug_concept_id int [not null]
  drug_type_concept_id int
  drug_exposure_start_date date
  drug_exposure_end_date date
  drug_source_value varchar(200)
  drug_source_concept_id int
  quantity decimal(18,6)
  days_supply int
  dose_unit_concept_id int
  route_concept_id int
  lot_number varchar(50)
  sig text
  source_value varchar(200)
  source_concept_id int
  // -- 13 metadata columns --
  source_type varchar(30)
  source_device_id uuid [ref: > device_registry.device_id]
  occurred_at timestamp [not null]
  trust_level varchar(10)
  quality_flag varchar(20)
  record_hash varchar(64)
}

Table cdm_device_exposure [headercolor: #6366f1] {
  device_exposure_id uuid [pk]
  person_id uuid [ref: > cdm_person.person_id, not null]
  device_concept_id int
  device_type_concept_id int
  device_exposure_start_date date
  device_exposure_end_date date
  unique_device_id varchar(200)
  device_source_value varchar(200)
  // -- metadata --
  source_type varchar(30)
  source_device_id uuid [ref: > device_registry.device_id]
  occurred_at timestamp
  record_hash varchar(64)
}

Table cdm_note [headercolor: #6366f1] {
  note_id uuid [pk]
  person_id uuid [ref: > cdm_person.person_id, not null]
  note_type_concept_id int
  note_text text
  note_date date
  encoding_concept_id int
  language_concept_id int
  source_file_url varchar(500)
  source_file_hash varchar(64)
  // -- metadata --
  source_type varchar(30)
  occurred_at timestamp
  trust_level varchar(10)
  sensitivity_level varchar(10)
  encrypted_value bytea
  encryption_key_id varchar(100)
  record_hash varchar(64)
}

Table cdm_episode [headercolor: #6366f1] {
  episode_id uuid [pk]
  person_id uuid [ref: > cdm_person.person_id, not null]
  episode_concept_id int
  episode_start_date date
  episode_end_date date
  episode_type_concept_id int
  episode_object_concept_id int
  episode_source_value varchar(200)
  severity varchar(20)
  resolution varchar(20)
}

Table cdm_episode_event [headercolor: #6366f1] {
  episode_event_id uuid [pk]
  episode_id uuid [ref: > cdm_episode.episode_id, not null]
  event_id uuid [not null]
  event_table varchar(50) [note: 'cdm_measurement|cdm_observation|...']
  event_type varchar(50)
}

// ─── uq_cdm: Consent ───

Table consent [headercolor: #6366f1] {
  consent_id uuid [pk]
  person_id uuid [ref: > cdm_person.person_id, not null]
  scope varchar(100) [not null]
  app_id varchar(50)
  status varchar(20) [default: 'PENDING', note: 'PENDING|APPROVED|REVOKED']
  xrpl_tx_hash varchar(64)
  revocation_tx_hash varchar(64)
  approved_at timestamp
  revoked_at timestamp
  expires_at timestamp
  created_at timestamp [default: `NOW()`]
  updated_at timestamp
}

Table cdm_consent_scope [headercolor: #6366f1] {
  id uuid [pk]
  consent_id uuid
  person_id uuid [ref: > cdm_person.person_id]
  research_project_id uuid [note: '논리참조 → uniqdata_db.research.project']
  consent_type varchar(30)
  domains jsonb [note: '허용 도메인 목록']
  purposes jsonb [note: '허용 목적 목록']
  granted_at timestamp
  expires_at timestamp
  revoked_at timestamp
  consent_hash varchar(64)
  xrpl_tx_hash varchar(64)
  is_active boolean [default: true]
}

// ─── uq_cdm: System Tables ───

Table anchor_log [headercolor: #6366f1] {
  anchor_id uuid [pk]
  person_id uuid [note: 'nullable — 탈퇴 시 NULL 유지 (보존)']
  anchor_type varchar(30) [note: 'CONSENT|REVOCATION|DATA_ACCESS|WALLET_BINDING']
  tx_hash varchar(64)
  memo_data text
  created_at timestamp [default: `NOW()`]
}

Table audit_log [headercolor: #6366f1] {
  audit_id uuid [pk]
  user_id uuid
  app_id varchar(50)
  action varchar(20) [note: 'READ|WRITE|DELETE|EXPORT']
  category varchar(50)
  metric varchar(50)
  record_count int
  metadata_json jsonb
  created_at timestamp [default: `NOW()`]
}

Table data_anchor_batch [headercolor: #6366f1] {
  id uuid [pk]
  batch_number bigint [unique]
  batch_start_at timestamp
  batch_end_at timestamp
  record_count int
  merkle_root varchar(128)
  merkle_tree_depth int
  merkle_tree_storage jsonb
  source_table_counts jsonb
  xrpl_tx_hash varchar(64)
  xrpl_tx_ledger bigint
  xrpl_account varchar(60)
  status varchar(20) [note: 'pending|submitted|confirmed|failed']
  created_at timestamp [default: `NOW()`]
}

Table record_revision [headercolor: #6366f1] {
  revision_id uuid [pk]
  source_table varchar(50)
  original_record_id uuid
  new_record_id uuid
  version int
  modified_by uuid
  modification_reason text
  created_at timestamp [default: `NOW()`]
}

Table quality_audit [headercolor: #6366f1] {
  audit_id uuid [pk]
  source_table varchar(50)
  source_record_id uuid
  checks_passed text [note: 'TEXT[] 배열']
  checks_failed text [note: 'TEXT[] 배열']
  outlier_zscore decimal(5,2)
  details jsonb
  created_at timestamp [default: `NOW()`]
}

Table dataset_registry [headercolor: #6366f1] {
  dataset_id uuid [pk]
  dataset_name varchar(200)
  dataset_version varchar(20)
  source_url text
  license varchar(100)
  citation text
  trust_level_default varchar(10)
  total_subjects int
  total_records int
  date_range_start date
  date_range_end date
  imported_at timestamp
  import_hash varchar(64)
  import_config jsonb
  notes text
}

Table uniqdata_concept [headercolor: #6366f1] {
  concept_id int [pk]
  concept_name varchar(255)
  concept_name_kr varchar(255) [note: '한국어 명칭']
  domain_id varchar(20)
  vocabulary_id varchar(20)
  concept_class_id varchar(20)
  standard_concept varchar(1)
  valid_start_date date
  valid_end_date date
  description text
}

Table feature_flag [headercolor: #6366f1] {
  id uuid [pk]
  flag_name varchar(100) [unique, not null]
  enabled boolean [not null, default: false]
  environment varchar(20) [default: 'all', note: 'dev|prod|all']
  description text
  created_at timestamp [default: `NOW()`]
  updated_at timestamp

  Note: 'DB 기반 + Redis 캐시 (5분 TTL). OFF 시 403 차단.'
}

// ─── Schema: uq_mapping (ID 매핑) ───

Table research_participant [headercolor: #a78bfa] {
  id uuid [pk]
  person_id uuid [not null, note: 'FK → cdm_person.person_id']
  project_id uuid [not null, note: '논리참조 → uniqdata_db.research.project']
  participant_number varchar(20) [not null, note: 'P001, P002... Enterprise가 보는 유일한 ID']
  participant_hash varchar(64)
  enrolled_at timestamp
  withdrawn_at timestamp
  status varchar(20) [default: 'active', note: 'active|withdrawn|completed']

  indexes {
    (person_id, project_id) [unique]
    participant_number
  }
}

Table institution_registry [headercolor: #a78bfa] {
  id uuid [pk]
  institution_code varchar(20) [unique, not null]
  institution_name varchar(200)
  enterprise_institution_id uuid [note: '논리참조 → uniqdata_db.enterprise.institution']
  is_active boolean [default: true]
  registered_at timestamp [default: `NOW()`]
}

Table linking_token [headercolor: #a78bfa] {
  id uuid [pk]
  person_id uuid [not null]
  memo varchar(200)
  token_hash varchar(128) [unique, not null]
  token_prefix varchar(8) [note: '토큰 코드 앞 8자리']
  status varchar(30) [default: 'active', note: 'active|carted|pending_consent|enrolled|declined|expired|revoked']
  created_at timestamp [default: `NOW()`]
  expires_at timestamp [note: '30일 TTL']
  institution_id uuid
  project_id uuid
  carted_at timestamp
  consent_requested_at timestamp
  consent_responded_at timestamp
  participant_number varchar(20)
  enrolled_at timestamp
  fail_count int [default: 0]
  locked_until timestamp

  Note: '환자가 앱에서 발급 → 연구자가 코드 입력 → 동의 → 등록'
}

Table deletion_audit_log [headercolor: #a78bfa] {
  id uuid [pk]
  person_id uuid
  project_id uuid
  deletion_type varchar(30) [note: 'project_withdrawal|full_withdrawal']
  tables_affected jsonb
  records_deleted int
  requested_at timestamp
  executed_at timestamp
  executed_by uuid
  status varchar(20) [default: 'pending', note: 'pending|executing|completed|failed']
  error_detail text

  Note: '컴플라이언스용 보존 — 탈퇴 후에도 삭제하지 않음'
}

// ╔══════════════════════════════════════════════════════════════════════════════════╗
// ║                                                                                ║
// ║   여기서부터 별도 DB — 직접 JOIN 불가 — Internal API로만 통신                   ║
// ║                                                                                ║
// ║   Core (health_db, FastAPI:8000) <── REST API ──> Business (uniqdata_db, Spring:8080)  ║
// ║                                                                                ║
// ║   Enterprise → Core 호출 (X-Service-Auth):                                     ║
// ║     POST /internal/matching/estimate        적격 대상자 추정                    ║
// ║     POST /internal/matching/recruit          모집 알림 발송                     ║
// ║     POST /internal/tier1/overview            시계열 집계 (그래프)               ║
// ║     POST /internal/tier1/table               참여자별 요약 (테이블)             ║
// ║     POST /internal/tier1/distribution        값 분포 (히스토그램, k-anonymous)  ║
// ║     POST /internal/token/preview             토큰 미리보기                      ║
// ║     POST /internal/token/cart                토큰 카트 추가                     ║
// ║     POST /internal/token/send-consent        동의 요청 발송                     ║
// ║     POST /internal/token/resolve             토큰→participant_number 변환       ║
// ║     POST /internal/escrow/create             프로젝트 지갑 생성                 ║
// ║     POST /internal/escrow/release            참여자 보상 지급                   ║
// ║     POST /internal/escrow/finalize           프로젝트 종료 정산                 ║
// ║     GET  /internal/health                    헬스체크                            ║
// ║                                                                                ║
// ║   Core → Enterprise 푸시:                                                      ║
// ║     POST   /api/enterprise/project/{id}/participant    참여자 등록              ║
// ║     POST   /api/enterprise/project/{id}/dataset        데이터 전송              ║
// ║     DELETE /api/enterprise/project/{id}/participant/{n} 동의 철회               ║
// ║     POST   /enterprise/push/withdrawal                 회원 탈퇴               ║
// ║                                                                                ║
// ║   cross-DB FK는 없음. person_id는 Core에만, participant_number만 Enterprise에   ║
// ║                                                                                ║
// ╚══════════════════════════════════════════════════════════════════════════════════╝

// ═══════════════════════════════════════════════════
// ░░░ uniqdata_db — Business Server (Spring:8080) ░░░
// 18 Tables · PostgreSQL 15 · research schema
// ═══════════════════════════════════════════════════

// ─── 7. 기관 ───

Table enterprises [headercolor: #059669] {
  id uuid [pk]
  name varchar(200) [not null]
  enterprise_type varchar(30) [note: 'HOSPITAL|PHARMA|CRO|UNIVERSITY|INSURANCE|GOVERNMENT']
  business_number varchar(20)
  irb_committee_id uuid
  status varchar(20) [default: 'ACTIVE']
  created_at timestamp [default: `NOW()`]
}

Table enterprise_members [headercolor: #059669] {
  id uuid [pk]
  enterprise_id uuid [ref: > enterprises.id]
  user_id uuid [not null, note: 'Enterprise 자체 인증 유저 ID (Core user_id 아님)']
  role varchar(20) [note: 'OWNER|PI|IRB_MEMBER|STAFF|VIEWER']
  status varchar(20) [default: 'ACTIVE']
  created_at timestamp [default: `NOW()`]

  indexes {
    (enterprise_id, user_id) [unique]
  }
}

// ─── 8. 연구 프로젝트 ───

Table projects [headercolor: #059669] {
  id uuid [pk]
  enterprise_id uuid [ref: > enterprises.id]
  title varchar(300) [not null]
  project_type varchar(30) [note: 'CLINICAL_TRIAL|OBSERVATIONAL|RETROSPECTIVE|REGISTRY|DATA_ANALYSIS']
  status varchar(30) [default: 'DRAFT', note: 'DRAFT|IRB_PENDING|IRB_APPROVED|RECRUITING|ACTIVE|DATA_LOCKED|ANALYSIS|COMPLETED']
  pi_user_id uuid [not null, note: '연구책임자 (Enterprise user_id)']
  irb_number varchar(50)
  target_participant_count int
  required_data_categories text [note: 'TEXT[] 배열']
  reward_per_participant decimal(18,6)
  total_reward_budget decimal(18,6)
  escrow_xrpl_tx_hash varchar(64)
  created_at timestamp [default: `NOW()`]
}

Table project_design [headercolor: #059669] {
  id uuid [pk]
  project_id uuid [ref: - projects.id, note: '1:1']
  irb_content jsonb [not null, note: 'AI 생성 IRB 연구 설계서 (연구목적, 방법론, 통계계획 등)']
  version int [default: 1]
  created_at timestamp [default: `NOW()`]
  updated_at timestamp
}

Table project_data_requirement [headercolor: #059669] {
  id uuid [pk]
  project_id uuid [ref: > projects.id]
  concept_id int [not null, note: 'OMOP concept_id 매핑']
  concept_name varchar(200)
  domain varchar(50) [note: 'measurement|observation|condition|drug']
  collection_frequency varchar(50) [note: 'daily|weekly|per_visit']
  required boolean [default: true]
  priority int
}

Table project_eligibility [headercolor: #059669] {
  id uuid [pk]
  project_id uuid [ref: > projects.id]
  concept_id int
  field varchar(50) [note: 'age|gender|condition|measurement']
  operator varchar(20) [note: 'eq|neq|gte|lte|between|in|not_in']
  value jsonb [not null]
  criteria_type varchar(20) [default: 'inclusion', note: 'inclusion|exclusion']
}

Table project_milestones [headercolor: #059669] {
  id uuid [pk]
  project_id uuid [ref: > projects.id]
  milestone_type varchar(30) [note: 'VISIT|ANALYSIS_POINT|IRB_SUBMISSION|RECRUITMENT_START|CLOSURE']
  label varchar(100) [note: 'V1, V2, M0, M3...']
  status varchar(20) [default: 'PENDING']
  target_date date
  completed_at timestamp
  sequence_order int
}

Table participants [headercolor: #059669] {
  id uuid [pk]
  project_id uuid [ref: > projects.id]
  participant_number varchar(20) [not null, note: 'P001, P002... (person_id 없음!)']
  status varchar(20) [default: 'ENROLLED', note: 'ENROLLED|ACTIVE|COMPLETED|WITHDRAWN|EXCLUDED']
  reward_earned decimal(18,6) [default: 0]
  reward_paid decimal(18,6) [default: 0]
  enrolled_at timestamp
  created_at timestamp [default: `NOW()`]

  indexes {
    (project_id, participant_number) [unique]
  }

  Note: 'person_id, user_id 없음. participant_number만 저장.'
}

Table participation_criteria [headercolor: #059669] {
  id uuid [pk]
  project_id uuid [ref: > projects.id]
  criteria_type varchar(20) [note: 'INCLUSION|EXCLUSION']
  field varchar(50) [note: 'age, gender, chronic_conditions']
  operator varchar(20) [note: 'EQUALS|BETWEEN|IN|NOT_IN|GTE|LTE']
  value jsonb
}

Table data_requests [headercolor: #059669] {
  id uuid [pk]
  project_id uuid [ref: > projects.id]
  requester_id uuid
  request_type varchar(30) [note: 'PARTICIPANT_DATA|AGGREGATE|EXPORT']
  data_categories text [note: 'TEXT[] 배열']
  status varchar(20) [default: 'PENDING']
  core_request_id uuid [note: 'Core Internal API 요청 ID']
  created_at timestamp [default: `NOW()`]
}

// ─── 9. IRB ───

Table irb_submissions [headercolor: #059669] {
  id uuid [pk]
  project_id uuid [ref: > projects.id]
  enterprise_id uuid [ref: > enterprises.id]
  submission_type varchar(30) [note: 'INITIAL|AMENDMENT|CONTINUING_REVIEW|CLOSURE']
  status varchar(30) [default: 'DRAFT', note: 'DRAFT|SUBMITTED|PRELIMINARY_REVIEW|FULL_BOARD_REVIEW|REVISION_REQUESTED|APPROVED|CONDITIONALLY_APPROVED|REJECTED']
  version int [default: 1]
  ai_generated boolean [default: false]
  ai_model_used varchar(50)
  approval_valid_until date
  created_at timestamp [default: `NOW()`]
}

Table irb_documents [headercolor: #059669] {
  id uuid [pk]
  submission_id uuid [ref: > irb_submissions.id]
  doc_type varchar(50) [note: 'PROTOCOL|CONSENT_FORM|INVESTIGATOR_BROCHURE|CASE_REPORT_FORM']
  title varchar(300)
  content text
  version int [default: 1]
  generated_by varchar(20) [note: 'AI|MANUAL|TEMPLATE']
  previous_version_id uuid [ref: > irb_documents.id]
  created_at timestamp [default: `NOW()`]
}

Table irb_review_comments [headercolor: #059669] {
  id uuid [pk]
  submission_id uuid [ref: > irb_submissions.id]
  reviewer_id uuid
  review_type varchar(20) [note: 'PRIMARY|SECONDARY|FULL_BOARD']
  decision varchar(20) [note: 'APPROVE|MINOR_REVISION|REJECT']
  comment text
  target_document_id uuid
  target_section varchar(100)
  is_confidential boolean [default: false]
  created_at timestamp [default: `NOW()`]
}

Table irb_workflow_history [headercolor: #059669] {
  id uuid [pk]
  submission_id uuid [ref: > irb_submissions.id]
  from_status varchar(30)
  to_status varchar(30)
  changed_by uuid
  reason text
  created_at timestamp [default: `NOW()`]
}

// ─── 10. 프로젝트 지갑 ───

Table project_wallets [headercolor: #059669] {
  id uuid [pk]
  project_id uuid [ref: - projects.id, note: '1:1 — 프로젝트당 지갑 1개']
  wallet_address varchar(60) [unique, not null, note: 'rPrj... Core가 생성한 XRPL 주소']
  budget_total decimal(18,6) [not null, default: 0]
  budget_deposited decimal(18,6) [default: 0]
  budget_spent decimal(18,6) [default: 0]
  status varchar(20) [default: 'CREATED', note: 'CREATED|FUNDED|ACTIVE|DEPLETED|CLOSED']
  created_at timestamp [default: `NOW()`]

  Note: '지갑 시드는 Core core_auth.escrow_secret에 KMS 암호화 저장. Enterprise는 주소만 알고 있음.'
}

Table project_wallet_transactions [headercolor: #059669] {
  id uuid [pk]
  project_wallet_id uuid [ref: > project_wallets.id, not null]
  tx_type varchar(30) [not null, note: 'DEPOSIT|WITHDRAWAL|REWARD_PAYOUT|REFUND']
  from_address varchar(60) [not null]
  to_address varchar(60) [not null]
  amount decimal(18,6) [not null]
  currency varchar(10) [default: 'XRP']
  xrpl_tx_hash varchar(64)
  memo varchar(200)
  status varchar(20) [default: 'PENDING', note: 'PENDING|CONFIRMED|FAILED']
  created_at timestamp [default: `NOW()`]

  indexes {
    (project_wallet_id, created_at)
  }
}

Table project_budget [headercolor: #059669] {
  id uuid [pk]
  project_id uuid [ref: > projects.id]
  category varchar(50) [note: 'participant_reward|platform_fee|data_storage|analysis']
  amount decimal(18,6)
  spent decimal(18,6) [default: 0]
  created_at timestamp [default: `NOW()`]
}

// ─── 11. 정산 ───

Table settlement_batches [headercolor: #059669] {
  id uuid [pk]
  project_id uuid [ref: > projects.id]
  batch_type varchar(30) [note: 'PARTICIPANT_REWARD|DATA_PURCHASE']
  status varchar(20) [default: 'PENDING', note: 'PENDING|CALCULATING|CORE_REQUESTED|ESCROW_PROCESSING|COMPLETED']
  total_amount decimal(18,6)
  currency varchar(10) [default: 'XRP']
  item_count int
  escrow_tx_hash varchar(64)
  created_at timestamp [default: `NOW()`]
}

Table settlement_items [headercolor: #059669] {
  id uuid [pk]
  batch_id uuid [ref: > settlement_batches.id]
  participant_number varchar(20) [not null, note: 'P001 (user_id 없음!)']
  amount decimal(18,6)
  calculation_basis jsonb [note: '{data_points_count, quality_avg, days}']
  status varchar(20) [default: 'PENDING', note: 'PENDING|PAID|FAILED|REFUNDED']
  paid_tx_hash varchar(64)
  paid_at timestamp

  Note: 'participant_number만 사용. Core가 /internal/escrow/release에서 지갑주소 역매핑 처리.'
}

// ─── 12. Phase 2 ───

Table synthetic_datasets [headercolor: #6b7280] {
  id uuid [pk]
  project_id uuid [ref: > projects.id]
  generation_method varchar(30) [note: 'GAN|VAE|CTGAN|RULE_BASED']
  source_data_summary jsonb
  row_count int
  quality_score decimal(3,2)
  reidentification_risk decimal(5,4)
  status varchar(20) [default: 'GENERATING']
  created_at timestamp [default: `NOW()`]

  Note: 'Phase 2'
}

Table fl_rounds [headercolor: #6b7280] {
  id uuid [pk]
  project_id uuid [ref: > projects.id]
  round_number int
  participating_nodes int
  dp_epsilon decimal(5,2) [note: 'Differential Privacy']
  aggregation_method varchar(30) [note: 'FedAvg|FedProx']
  status varchar(20) [default: 'PENDING']
  created_at timestamp [default: `NOW()`]

  Note: 'Phase 2'
}

// ─── 13. 시스템 ───

Table webhook_events [headercolor: #059669] {
  id uuid [pk]
  event_type varchar(50) [note: 'participant.enrolled|data.submitted|consent.revoked|escrow.created|account.deleted']
  source varchar(20) [default: 'CORE']
  payload jsonb
  status varchar(20) [default: 'RECEIVED', note: 'RECEIVED|PROCESSED|FAILED|RETRYING']
  retry_count int [default: 0]
  error_message text
  created_at timestamp [default: `NOW()`]
}
